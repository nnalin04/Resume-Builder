# =============================================================================
# AI Resume Builder — backend/.env.example
# Copy this to backend/.env and fill in the values.
# This file is safe to commit — it contains NO real secrets.
# =============================================================================

# ─── AI / Gemini ─────────────────────────────────────────────────────────────
# Google AI Studio → https://aistudio.google.com/app/apikey
# Free tier: 1,500 req/day  |  Model: gemini-2.5-flash
# Prod value: set in backend/.env on Oracle server
GEMINI_API_KEY=

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=

# ─── Backend Security (Vercel ↔ Oracle shared secret) ────────────────────────
# Vercel serverless proxy injects this as X-Backend-Secret header.
# FastAPI middleware rejects ALL requests without it (returns 403).
# Must EXACTLY match BACKEND_SECRET set in Vercel env vars.
# Generate: openssl rand -hex 32
# See oracle-setup.sh line 8 for the current prod value.
# Leave empty in local dev to disable the check.
BACKEND_SECRET=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Production: https://resume-builder-black-nu.vercel.app
# Local dev:  http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# ─── Password Reset ───────────────────────────────────────────────────────────
# Base URL used to build reset links in emails.
# Must match your frontend URL (same as FRONTEND_ORIGIN).
# Production: https://resume-builder-black-nu.vercel.app
FRONTEND_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
# Set automatically by docker-compose.yml when running via Docker.
# Do NOT change when running via Docker Compose.
DATABASE_URL=sqlite:////app/data/resume_builder.db

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <FRONTEND_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
# Production redirect: https://resume-builder-black-nu.vercel.app/auth/google/callback

# ─── Payments — Cashfree ─────────────────────────────────────────────────────
# https://merchant.cashfree.com
# Sign up before March 31 2026 for 1.6% promotional rate!
# CASHFREE_ENV: "sandbox" for testing, "production" for live
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox
CASHFREE_WEBHOOK_URL=https://resume-builder-black-nu.vercel.app/api/payments/webhook

# ─── Email / SMTP (optional — for password reset emails) ─────────────────────
# Without SMTP, reset links are only logged to console (safe dev fallback).
#
# Gmail App Password setup:
#   1. Enable 2FA at myaccount.google.com/security
#   2. Go to myaccount.google.com/apppasswords
#   3. Create App Password for "Mail"
#   4. Use the 16-char code as SMTP_PASS (NOT your real Gmail password)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Resume Builder <noreply@resumebuilder.app>

# ─── Environment ──────────────────────────────────────────────────────────────
# Set to "development" locally so password-reset links appear in logs when SMTP
# is not configured. In production, leave unset or set to "production".
ENV=development

# ─── Sentry error monitoring ──────────────────────────────────────────────────
# Free tier: 5,000 errors/month — https://sentry.io (create a Python project)
# Leave empty to disable Sentry on the backend.
SENTRY_DSN=

# Frontend Sentry DSN — passed to Vite as VITE_SENTRY_DSN (create a React project)
# Can be the same DSN as SENTRY_DSN; Sentry separates events by platform.
# Set this in frontend/.env (or frontend/.env.local) as well.
VITE_SENTRY_DSN=
